{
  "name": "fifotv",
  "version": "2.0.0",
  "license": "GPL-3.0-only",
  "description": "FIFOtv — Smart TV kiosk",
  "main": "electron/main.js",
  "scripts": {
    "dev": "electron .",
    "dev:mac": "bash scripts/dev-macos.sh",
    "start": "electron . --kiosk",
    "postinstall": "node scripts/bootstrap-electron.js",
    "test": "node --test test/*.test.js",
    "check": "node --check electron/*.js && node --check electron/views/*.js && node --check electron/views/spatial-navigation/*.js && node --check electron/views/streaming-customizations/*.js && node --check frontend/*.js && node --test test/*.test.js",
    "build": "electron-builder --linux deb",
    "dist": "electron-builder --linux AppImage"
  },
  "dependencies": {
    "dbus-next": "^0.10.2",
    "electron-log": "^5.4.4"
  },
  "devDependencies": {
    "@electron/get": "^5.0.0",
    "electron": "https://codeload.github.com/castlabs/electron-releases/tar.gz/refs/tags/v42.3.3+wvcus",
    "extract-zip": "^2.0.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.fifotv.app",
    "productName": "FIFOtv",
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "AudioVideo"
    },
    "files": [
      "electron/**/*",
      "frontend/**/*",
      "package.json"
    ]
  }
}
